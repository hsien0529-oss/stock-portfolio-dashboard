<!-- SECTION: CHART -->
<div class="section" id="sec-chart">
  <div class="page">
    <div class="card grid-full">
      <div class="card-header">
        <div class="card-title">📈 K線圖 — TradingView</div>
        <div class="tv-selector">
          <label style="font-size:0.73rem;color:var(--text2)">股票：</label>
          <input type="text" id="tvSearch" placeholder="🔍 搜尋..." 
            style="background:var(--surface2);border:1px solid var(--border);color:var(--text);padding:2px 8px;border-radius:5px;font-size:0.72rem;width:100px"
            oninput="filterTVSelector(this.value)"
            onfocus="this.style.borderColor='var(--blue)'"
            onblur="setTimeout(()=>{this.style.borderColor='var(--border)'},200)">
          <select id="tvSymbol" onchange="loadTVWidget()" style="background:var(--surface2);border:1px solid var(--border);color:var(--text);padding:2px 6px;border-radius:5px;font-size:0.75rem;min-width:110px"></select>
          <span style="font-size:0.68rem;color:var(--text3);margin-left:4px">周期：</span>
          <button class="btn btn-sm tv-ival-btn" onclick="setTVInterval('5',this)" title="按 D 鍵">5分</button>
          <button class="btn btn-sm tv-ival-btn" onclick="setTVInterval('15',this)" title="按 H 鍵">15分</button>
          <button class="btn btn-sm tv-ival-btn active" onclick="setTVInterval('60',this)" title="按 H 鍵">60分</button>
          <button class="btn btn-sm tv-ival-btn" onclick="setTVInterval('D',this)" title="按 D 鍵">日線</button>
          <button class="btn btn-sm tv-ival-btn" onclick="setTVInterval('W',this)" title="按 W 鍵">週線</button>
          <button class="btn btn-sm" onclick="loadTVWidget()" title="重載">🔄</button>
          <button class="btn btn-sm" onclick="navigateTVPrev()" title="上一檔 (←)">◀</button>
          <button class="btn btn-sm" onclick="navigateTVNext()" title="下一檔 (→)">▶</button>
          <a id="tvExternalLink2" href="#" target="_blank" class="btn btn-sm" style="text-decoration:none" title="在新分頁開啟" onclick="document.getElementById('tvExternalLink').click()">🌐</a>
        </div>
      </div>
      <!-- hidden original select kept for compatibility -->
      <select id="tvInterval" onchange="loadTVWidget()" style="display:none">
        <option value="D">日線</option>
        <option value="W">週線</option>
        <option value="60" selected>60分</option><option value="120">2小時</option><option value="240">4小時</option>
        <option value="15">15分</option>
        <option value="5">5分</option>
      </select>
      <div class="tv-container" id="tvContainer">
        <!-- Status bar: shows stock info, loading state, and external links -->
        <div class="tv-status-bar" id="tvStatusBar">
          <span class="tv-status-dot" id="tvStatusDot"></span>
          <span id="tvStatusText" style="color:var(--text2)">等待載入...</span>
          <span style="margin-left:auto;display:flex;align-items:center;gap:8px;flex-wrap:wrap">
            <span id="tvStockName2" style="font-weight:700;color:var(--blue)">--</span>
            <span id="tvStockPrice2" style="font-family:var(--font-mono);font-weight:700;color:var(--text)">--</span>
            <span id="tvStockChange2" style="font-family:var(--font-mono);font-weight:700">--</span>
            <span class="tv-stock-chip" id="tvStockPE2" style="border-color:rgba(77,159,255,0.2)">
              <span style="color:var(--text3)">P/E</span><span style="font-family:var(--font-mono)">--</span>
            </span>
            <span class="tv-stock-chip" id="tvStockDiv2">
              <span style="color:var(--text3)">殖</span><span style="font-family:var(--font-mono)">--</span>
            </span>
            <span class="tv-stock-chip" id="tvStock52W2" style="border-color:rgba(255,176,32,0.2)">
              <span style="color:var(--text3)">52W</span><span style="font-family:var(--font-mono)">--</span>
            </span>
          </span>
          <span style="margin-left:8px;display:flex;gap:6px">
            <a id="tvExternalLink" href="#" target="_blank" class="btn btn-sm" style="text-decoration:none;padding:2px 8px" title="在 TradingView 開啟">🌐</a>
            <a id="tvYhooLink" href="#" target="_blank" class="btn btn-sm" style="text-decoration:none;padding:2px 8px" title="Yahoo 股市">📈</a>
            <a id="tvGoodinfoLink" href="#" target="_blank" class="btn btn-sm" style="text-decoration:none;padding:2px 8px" title="GoodInfo">📊</a>
            <a id="tvNewsLink" href="#" target="_blank" class="btn btn-sm" style="text-decoration:none;padding:2px 8px" title="最新新聞">📰</a>
          </span>
        </div>
        <!-- Loading overlay -->
        <div class="tv-loading" id="tvLoading">
          <div class="tv-loading-spinner"></div>
          <div style="color:var(--text2);font-size:0.78rem;margin-top:4px">載入 TradingView K線圖...</div>
          <div style="font-size:0.62rem;color:var(--text3);margin-top:2px" id="tvLoadingHint">若無法載入，15秒後自動切換本地圖表</div>
          <div style="margin-top:8px;display:flex;gap:6px;justify-content:center">
            <a href="https://www.tradingview.com/chart/?symbol=TWSE:2330" target="_blank" class="btn btn-sm" style="text-decoration:none;opacity:0.7" title="備用連結">🌐 直接開啟</a>
            <button class="btn btn-sm" onclick="loadTVFallback(document.getElementById('tvSymbol')?.value?.replace('TWSE:','')||'2330')" style="opacity:0.7">📊 跳過等待</button>
          </div>
        </div>
        <!-- Chart widget container -->
        <div id="tradingview-widget" style="width:100%;flex:1;min-height:360px;position:relative"></div>
      </div>
      <div class="tv-note">📌 點擊任一檔股票代號可跳至 K線圖 · 支援鍵盤快捷鍵 1-7 切換頁面</div>
    </div>
  </div>
</div>

