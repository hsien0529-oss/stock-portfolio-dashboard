            <div id="holdingSummary" style="display:flex;flex-direction:column;gap:0"></div>
          </div>
        </div>

        <!-- sector allocation -->
        <div class="card mb12">
          <div class="card-header">
            <div class="card-title">🏭 產業分佈</div>
          </div>
          <div class="card-body">
            <div class="sector-list" id="sectorList"></div>
          </div>
        </div>

        <!-- quick stats -->
        <div class="card mb12">
          <div class="card-header">
            <div class="card-title">📈 組合分析</div>
          </div>
          <div class="card-body">
            <div class="metrics-grid" id="portfolioMetrics"></div>
          </div>
        </div>

        <!-- concentration risk alerts -->
        <div class="card mb12">
          <div class="card-header">
            <div class="card-title">🚨 風險警示</div>
            <div class="text-xs" style="color:var(--text3);font-size:0.62rem">52W位置 + PE + 集中度</div>
          </div>
          <div class="card-body">
            <div id="concentrationRiskList"></div>
          </div>
        </div>

        <!-- concentration -->
        <div class="card mb12">
          <div class="card-header">
            <div class="card-title">⚠️ 集中度</div>
          </div>
          <div class="card-body">
            <div class="concentration-list" id="concentrationList"></div>
          </div>
        </div>

        <!-- import/export -->
        <div class="card">
          <div class="card-header">
            <div class="card-title">💾 匯入 / 匯出</div>
          </div>
          <div class="card-body">
            <div class="io-row">
              <button class="btn btn-green" onclick="exportPortfolio()">📤 匯出</button>
              <button class="btn" onclick="document.getElementById('importFile').click()">📥 匯入</button>
              <input type="file" id="importFile" accept=".json" onchange="importPortfolio(event)">
            </div>
            <div class="hint-text" id="ioStatus"></div>
          </div>
        </div>

      </div>
    </div>
