  <div class="qs-divider"></div>
  <div class="qs-item"><span class="qs-label">最大產業</span><span class="qs-value" id="qsTopSectorA">--</span></div>
  <div class="qs-divider"></div>
  <div class="qs-item"><span class="qs-label">台積電</span><span class="qs-value" id="qsTSMCA">--</span></div>
    <div class="qs-divider"></div>
    <div class="qs-item"><span class="qs-label">加權</span><span class="qs-value" id="qsTWIIA">--</span></div>
    <div class="qs-divider"></div>
    <div class="qs-item" id="lastTradingDayNote" style="font-size:0.6rem;color:var(--text3);min-width:max-content;white-space:nowrap"></div>
    <div class="qs-divider"></div>
    <div class="qs-item" id="dataFreshnessBadge" style="font-size:0.58rem;color:var(--green);min-width:max-content;white-space:nowrap;display:flex;align-items:center;gap:3px">
      <span id="freshnessDot" style="display:inline-block;width:5px;height:5px;border-radius:50%;background:var(--green)"></span>
