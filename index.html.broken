      </div>
      <div class="card-body" style="padding:8px 14px 10px">
        <div style="display:flex;gap:12px;flex-wrap:wrap" id="sectorAllocationBars"></div>
      </div>
    </div>

    <!-- Top Movers -->
    <div class="card mb12">
      <div class="card-header">
        <div class="card-title">🔥 今日重點股</div>
        <div class="text-xs" style="color:var(--text3)">日報酬率</div>
      </div>
      <div class="card-body" id="topMoversCard">
        <div style="display:flex;gap:8px;overflow-x:auto;padding-bottom:4px" id="topMoversRow"></div>
        <div style="font-size:0.62rem;color:var(--text3);margin-top:6px" id="marketSummaryNote">📌 資料載入中...</div>
      </div>
    </div>

    <!-- Portfolio News Digest -->
    <div class="card mb12">
      <div class="card-header">
        <div class="card-title">📰 持股相關新聞</div>
        <div class="text-xs" style="color:var(--text3);font-size:0.62rem">🔢 與組合相關的市場資訊</div>
      </div>
      <div class="card-body">
        <div id="portfolioNewsDigest"></div>
      </div>
