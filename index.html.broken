        <div class="daily-pl-sub" id="dailyWinSub">--</div>
      </div>
    </div>

    <!-- Alerts -->
    <div id="alertBanner" class="mb8"></div>

    <!-- Market Indices -->
    <div class="card mb12">
      <div class="card-header">
