            <div class="card-badge neu" id="portfolioBadge">--</div>
          </div>
          <div class="global-summary">
            <div class="gs-item">
              <div class="gs-label">總市值</div>
              <div class="gs-value" id="gsMV">--</div>
            </div>
            <div class="gs-item">
              <div class="gs-label">總成本</div>
              <div class="gs-value" id="gsCost">--</div>
            </div>
            <div class="gs-item">
              <div class="gs-label">未實現損益</div>
              <div class="gs-value" id="gsGain">--</div>
              <div class="gs-sub" id="gsGainPct">--</div>
            </div>
            <div class="gs-item">
              <div class="gs-label">日報酬</div>
              <div class="gs-value" id="gsDay">--</div>
              <div class="gs-sub" id="gsDayPct">--</div>
            </div>
            <div class="gs-item">
              <div class="gs-label">自起始日</div>
              <div class="gs-value" id="gsSinceStart">--</div>
              <div class="gs-sub" id="gsSinceStartPct">--</div>
            </div>
            <div class="gs-item">
              <div class="gs-label">持有期間</div>
              <div class="gs-value" id="gsHoldingDays" style="font-size:0.85rem">--</div>
            </div>
          </div>

          <!-- Benchmark Comparison Strip -->
          <div class="benchmark-strip" id="benchmarkStrip" style="margin-top:10px">
            <div class="benchmark-item">
              <div class="benchmark-label">加權指數</div>
              <div class="benchmark-value" id="bmTWII">--</div>
              <div class="benchmark-delta" id="bmTWIIChg">--</div>
            </div>
            <div class="benchmark-item">
              <div class="benchmark-label">NASDAQ</div>
              <div class="benchmark-value" id="bmNASDAQ">--</div>
              <div class="benchmark-delta" id="bmNASDAQChg">--</div>
            </div>
            <div class="benchmark-item">
              <div class="benchmark-label">S&amp;P 500</div>
              <div class="benchmark-value" id="bmSPX">--</div>
              <div class="benchmark-delta" id="bmSPXChg">--</div>
            </div>
            <div class="benchmark-item">
              <div class="benchmark-label">道瓊</div>
              <div class="benchmark-value" id="bmDJI">--</div>
              <div class="benchmark-delta" id="bmDJIChg">--</div>
            </div>
            <div class="benchmark-item">
              <div class="benchmark-label">恆生</div>
              <div class="benchmark-value" id="bmHK">--</div>
              <div class="benchmark-delta" id="bmHKChg">--</div>
            </div>
            <div class="benchmark-item">
              <div class="benchmark-label">台積電</div>
              <div class="benchmark-value" id="bmTSMC">--</div>
              <div class="benchmark-delta" id="bmTSMCChg">--</div>
            </div>
            <div class="benchmark-item">
              <div class="benchmark-label">鴻海</div>
              <div class="benchmark-value" id="bmHNH">--</div>
              <div class="benchmark-delta" id="bmHNHChg">--</div>
            </div>
          </div>

          <!-- Sector Allocation Mini View -->
          <div id="sectorAllocationMini" style="margin-top:10px;display:none">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
              <div style="font-size:0.6rem;color:var(--text3);text-transform:uppercase;letter-spacing:0.06em;font-weight:700">產業配置</div>
              <div id="sectorCountMini" style="font-size:0.58rem;color:var(--text3)"></div>
            </div>
            <div id="sectorBarsMini" style="display:flex;flex-direction:column;gap:5px"></div>
          </div>
        </div>

        <!-- Portfolio Health Bar -->
        <div class="card mb12">
          <div class="card-header">
            <div class="card-title">💹 組合健康度</div>
            <div class="text-xs" style="color:var(--text3);font-size:0.62rem">與大盤 (TAIEX) 對比</div>
          </div>
          <div class="card-body" style="padding:10px 14px">
            <!-- Quick Stats Mini Strip -->
            <div style="display:flex;gap:8px;padding:6px 14px;margin:-12px -14px 10px;background:var(--surface2);border-bottom:1px solid var(--border);flex-wrap:wrap;align-items:center" id="quickStatsStrip">
              <div id="taiexSparkline2" style="display:inline-flex;align-items:center"></div>
              <div id="quickStatsContent" style="display:flex;gap:12px;flex-wrap:wrap;align-items:center"></div>
            </div>
            <div class="portfolio-health" id="portfolioHealth"></div>
            <div id="benchmarkComparison"></div>
          </div>
        </div>

        <!-- Dividend Summary -->
        <div class="card mb12">
          <div class="card-header">
            <div class="card-title">💰 殖利率摘要</div>
            <div class="text-xs" style="color:var(--text3);font-size:0.62rem">含 ETF 平均殖利率</div>
          </div>
          <div class="dividend-summary" id="dividendSummary"></div>
        </div>

        <!-- Actionable Alerts -->
        <div class="card mb12" id="actionableAlertsCard">
          <div class="card-header">
            <div class="card-title">🔔 投資洞察</div>
            <div class="text-xs" style="color:var(--text3);font-size:0.62rem">⚠️ 僅供參考</div>
          </div>
          <div class="card-body" style="padding:8px 14px">
            <div id="actionableAlerts"></div>
          </div>
        </div>

        <!-- family cards -->
        <div class="card mb12">
          <div class="card-header">
            <div class="card-title">👨‍👩‍👦‍👦 家庭成員</div>
          </div>
          <div class="card-body">
            <div class="family-cards" id="familyCards"></div>
          </div>
        </div>

        <!-- Portfolio Rebalancing Suggestions -->
        <div class="card mb12">
          <div class="card-header">
            <div class="card-title">⚖️ 配置診斷</div>
            <div class="text-xs" style="color:var(--text3)">再平衡建議</div>
          </div>
          <div class="card-body">
            <div id="rebalancingSuggestions"></div>
          </div>
        </div>

        <!-- Top Movers Row -->
        <div class="card mb12">
          <div class="card-header">
            <div class="card-title">🚀 今日強弱勢股</div>
            <div class="text-xs" style="color:var(--text3);font-size:0.62rem">日漲跌幅排行</div>
          </div>
          <div class="card-body">
            <div class="mover-cards" id="moverCards"></div>
          </div>
        </div>

        <!-- allocation pie -->
        <div class="card">
          <div class="card-header">
            <div class="card-title">🥧 資產配置</div>
          </div>
          <div class="card-body">
            <div class="pie-container"><canvas id="pieChart"></canvas></div>
          </div>
        </div>
      </div>

      <!-- RIGHT -->
      <div class="grid-right">
        <!-- holdings summary -->
        <div class="card mb12">
          <div class="card-header">
            <div class="card-title">📌 持股概況</div>
            <div class="text-xs" style="color:var(--text3);font-size:0.62rem">Top 10 依市值</div>
          </div>
