<!-- SECTION: OVERVIEW -->
<div class="section active" id="sec-overview">
  <div class="page">
    <!-- Portfolio today's snapshot banner -->
    <div id="portfolioSnapshotBanner"></div>
    <!-- Enhanced market pulse row -->
    <div id="marketPulseRow" style="display:none;margin-bottom:8px"></div>
    <div class="card mb8" id="marketContextCard" style="padding:10px 14px;background:linear-gradient(135deg,var(--surface2) 0%,var(--bg) 100%;border:1px solid rgba(255,176,32,0.15)">
      <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
        <div style="font-size:0.65rem;font-weight:700;color:var(--amber);background:rgba(255,176,32,0.08);padding:3px 8px;border-radius:10px;border:1px solid rgba(255,176,32,0.2)">⚠️ 今日市場</div>
        <div style="flex:1;display:flex;gap:6px;flex-wrap:wrap">
          <div id="mcTWII" style="font-size:0.7rem;color:var(--text2)">加權 <span class="up">--</span></div>
          <div style="font-size:0.7rem;color:var(--text3)">|</div>
          <div id="mcSOX" style="font-size:0.7rem;color:var(--text2)">費半 <span class="down">--</span></div>
          <div style="font-size:0.7rem;color:var(--text3)">|</div>
          <div id="mcUS" style="font-size:0.7rem;color:var(--text2)">美股 <span>--</span></div>
          <div style="font-size:0.7rem;color:var(--text3)">|</div>
          <div id="mcTheme" style="font-size:0.7rem;color:var(--text)">科技股領跌</div>
        </div>
        <div style="font-size:0.62rem;color:var(--text3)" id="mcTime">--:-- 更新</div>
      </div>
    </div>
    <div class="card mb8" id="dailyPLSummary" style="padding:8px 14px;background:linear-gradient(135deg,var(--surface2) 0%,var(--bg) 100%"></div>

    <!-- Today at a Glance — quick portfolio snapshot -->
    <div class="card mb8" id="todayGlanceCard" style="padding:10px 14px">
      <div style="font-size:0.65rem;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:8px">📌 今日概況</div>
      <div id="todayGlanceContent" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:8px"></div>
    </div>

    <!-- Quick Stats Strip -->
    <div id="quickStatsStrip" class="card mb8" style="padding:8px 14px;display:flex;align-items:center;gap:10px;flex-wrap:wrap">
      <div class="quick-stat-chip" id="qsWinRateChip">
        <span>勝率</span>
        <span class="val" id="qsWinRate2">--</span>
      </div>
      <div class="quick-stat-chip" id="qsCountChip">
        <span>持股</span>
        <span class="val" id="qsCount2">--</span>
      </div>
      <div class="quick-stat-chip" id="qsSectorChip">
        <span>最大產業</span>
        <span class="val" id="qsTopSector2">--</span>
      </div>
      <div class="quick-stat-chip" id="qsTwiiChip">
        <span>加權</span>
        <span class="val" id="qsTWII2">--</span>
      </div>
      <div class="quick-stat-chip" id="qsTsmcChip">
        <span>台積電</span>
        <span class="val" id="qsTSMC2">--</span>
      </div>
      <div style="margin-left:auto;display:flex;align-items:center;gap:6px">
        <div id="autoRefreshBadge" style="display:flex;align-items:center;gap:4px;font-size:0.62rem;color:var(--text3);background:var(--surface2);padding:3px 8px;border-radius:10px;border:1px solid var(--border)">
          <div id="refreshSpinner" style="width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse-dot 2s infinite"></div>
          <span id="refreshTimer">下次更新 15m</span>
        </div>
      </div>
    </div>

    <!-- Portfolio Gauge Summary -->
    <div id="portfolioGaugeRow" class="card mb8" style="padding:10px 14px">
      <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
        <div id="gaugeCanvas" style="width:80px;height:58px;flex-shrink:0">
          <canvas id="gaugeChart" width="160" height="116" style="width:80px;height:58px"></canvas>
        </div>
        <div style="flex:1;min-width:200px">
          <div style="font-size:0.65rem;color:var(--text3);margin-bottom:4px;text-transform:uppercase;letter-spacing:0.06em">📊 組合概況</div>
          <div style="display:flex;gap:12px;flex-wrap:wrap">
            <div style="text-align:center">
              <div style="font-size:0.6rem;color:var(--text3)">總市值</div>
              <div style="font-size:1.0rem;font-weight:700;font-family:var(--font-mono)" id="gaugeMV">--</div>
            </div>
            <div style="text-align:center">
              <div style="font-size:0.6rem;color:var(--text3)">日報酬</div>
              <div style="font-size:1.0rem;font-weight:700;font-family:var(--font-mono)" id="gaugeDay">--</div>
            </div>
            <div style="text-align:center">
              <div style="font-size:0.6rem;color:var(--text3)">α 超額</div>
              <div style="font-size:1.0rem;font-weight:700;font-family:var(--font-mono)" id="gaugeAlpha">--</div>
            </div>
            <div style="text-align:center">
              <div style="font-size:0.6rem;color:var(--text3)">勝率</div>
              <div style="font-size:1.0rem;font-weight:700;font-family:var(--font-mono)" id="gaugeWin">--</div>
            </div>
          </div>
        </div>
        <div style="text-align:center;flex-shrink:0">
          <div style="font-size:0.6rem;color:var(--text3)">組合情緒</div>
          <div style="font-size:1.2rem;font-weight:700" id="gaugeMood">--</div>
        </div>
      </div>
    </div>

    <!-- Daily P/L Summary Card -->
    <div id="dailyPLCard" class="daily-pl-card">
