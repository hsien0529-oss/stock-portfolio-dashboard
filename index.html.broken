          <span style="font-size:0.62rem;color:var(--text3);text-transform:uppercase;letter-spacing:0.04em">各產業今日表現</span>
          <span style="font-size:0.6rem;color:var(--text3)" id="sectorTWIIPct">加權指數 ▼ 0.96%</span>
        </div>
        <div style="display:flex;gap:4px;flex-wrap:wrap" id="sectorPulseBars"></div>
      </div>
    </div>

    <div class="main-grid">
      <!-- LEFT -->
      <div>
        <!-- global summary -->
        <div class="card mb12">
          <div class="card-header">
